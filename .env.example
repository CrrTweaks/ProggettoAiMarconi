# ──────────────────────────────────────────────
# AI School Workspace - Environment Variables
# ──────────────────────────────────────────────

# ── Common ──
NODE_ENV=development
TZ=Europe/Rome

# ── Supabase / Postgres ──
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aischool

# ── JWT ──
JWT_ACCESS_SECRET=replace-with-a-very-long-random-string
JWT_REFRESH_SECRET=replace-with-another-very-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Backend Node.js ──
NODE_PORT=4000
NODE_HOST=0.0.0.0
# Comma-separated list of allowed origins.
# In dev (NODE_ENV != production) any http(s)://localhost:* is auto-allowed.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
AI_SERVICE_URL=http://localhost:8000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Backend AI (FastAPI) ──
AI_PORT=8000
AI_HOST=0.0.0.0
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
PGVECTOR_DIM=768
UPLOAD_DIR=./uploads
MAX_PDF_MB=25

# ── Frontend (Vite) ──
VITE_API_URL=http://localhost:4000
VITE_AI_URL=http://localhost:8000
VITE_WS_URL=http://localhost:4000
VITE_APP_NAME=AI School Workspace
